# Backend Environment Variables - Example
# Copy this to .env and fill in the values

# Database Configuration
# For development: sqlite:///dev.db
# For production: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///dev.db

# Authentication Tokens (comma-separated for multiple tokens)
# Leave empty to disable authentication for local development
INGEST_API_TOKENS=

# Search Cache TTL (in seconds)
SEARCH_CACHE_TTL_SECONDS=60

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# OTP and Email Delivery
OTP_EXPIRE_MINUTES=10
OTP_DEBUG_EXPOSE_CODE=true
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SEND_FROM_MAIL=
SMTP_USE_STARTTLS=true
SMTP_TIMEOUT_SECONDS=20
